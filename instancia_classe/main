from carro import Carros
from moto import Motos

carro1 = Carros('toyota','Corola',4)
carro2 = Carros('honda','civic',2)
carro3 = Carros('ford','fusion',4)

moto1 = Motos('harley-davidson','street 750','esportiva')
moto2 = Motos('honda','cb 500','casual')
moto3 = Motos('yamaha','mt-09','esportiva')

print(carro1)
print(carro2)
print(carro3)

print(moto1)
print(moto2)
print(moto3)
