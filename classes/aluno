class Aluno:
    def __init__(self,nome,nota1,nota2):
        self.nome = nome
        self.nota1 = nota1
        self.nota2 = nota2

    def exibir_dados(self):
        print(f"Nome:{self.nome},nota1:{self.nota1},nota2:{self.nota2}")

aluno1 = Aluno("Anna",7,9)
aluno2 =Aluno("Juliana",10,4)

aluno1.exibir_dados()
aluno2.exibir_dados()
